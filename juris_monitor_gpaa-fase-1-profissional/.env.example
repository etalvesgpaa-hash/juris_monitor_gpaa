# ═══════════════════════════════════════════════════════════════════════
# JURISMONITOR - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# 🗄️ SUPABASE (Obrigatório)
# ─────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# ─────────────────────────────────────────────────────────────────────────
# 📧 EMAIL - GMAIL (Recomendado)
# ─────────────────────────────────────────────────────────────────────────
# Ative esta opção para usar Gmail
USE_GMAIL=true

# Seu e-mail do Gmail
GMAIL_USER=seu-email@gmail.com

# Senha de App do Gmail (16 caracteres sem espaços)
# Gere em: https://myaccount.google.com/apppasswords
# IMPORTANTE: Precisa ter autenticação em 2 fatores ativada!
GMAIL_APP_PASSWORD=abcdefghijklmnop

# ─────────────────────────────────────────────────────────────────────────
# 📧 EMAIL - RESEND (Alternativa/Fallback)
# ─────────────────────────────────────────────────────────────────────────
# API Key do Resend (opcional se usar Gmail)
# Obtenha em: https://resend.com/api-keys
# RESEND_API_KEY=re_sua_chave_aqui

# ─────────────────────────────────────────────────────────────────────────
# 🤖 IA - GROQ (Opcional)
# ─────────────────────────────────────────────────────────────────────────
# Para resumos automáticos de intimações com IA
# Obtenha em: https://console.groq.com/keys
# GROQ_API_KEY=gsk_sua_chave_aqui

# ─────────────────────────────────────────────────────────────────────────
# 🌐 URLS (Opcional)
# ─────────────────────────────────────────────────────────────────────────
# URL do portal do cliente (para links nos emails)
# PORTAL_URL=https://seu-site.vercel.app

# ═══════════════════════════════════════════════════════════════════════
# INSTRUÇÕES
# ═══════════════════════════════════════════════════════════════════════
#
# 1. Copie este arquivo para .env.local:
#    cp .env.example .env.local
#
# 2. Preencha as variáveis com seus valores reais
#
# 3. NUNCA commite o arquivo .env.local no Git!
#
# 4. Para produção (Vercel), configure as variáveis em:
#    Settings → Environment Variables
#
# ═══════════════════════════════════════════════════════════════════════
